# Build-time env vars for the admin SvelteKit SPA.
#
# Copy to `.env` (or `.env.local`, `.env.production`) and fill in real values.
# Vite reads these at build time and inlines them via `import.meta.env.*`.
# Only variables prefixed `VITE_` are exposed to client code — see
# https://vitejs.dev/guide/env-and-mode.html for the full rules.

# Root URL of the Worker API. Used by the proposal page's "Preview
# presentation" button to open `${VITE_API_URL_BASE}/p/:token` in a new tab.
# Dev: defaults to http://localhost:8787 (wrangler dev) if unset.
# Prod: set to whatever DNS resolves to the Worker (e.g. https://api.busseyandbussey.com).
VITE_API_URL_BASE=http://localhost:8787
